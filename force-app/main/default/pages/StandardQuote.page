                <table style="width:auto; border-collapse:collapse; table-layout:fixed; margin-left:1cm; margin-right:1cm; margin-top:1cm; font-weight:normal;">
                    
                    <thead>
                        <tr>
                            <th style="width:5%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">NO.</th>
                            <th style="width:18%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">DESCRIPTION</th>
                            <th style="width:10%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">AREAS</th>
                            <th style="width:10%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">QNTY / SQFT</th>
                            <th style="width:10%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">QNTY / NO</th>
                            <th style="width:15%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">MRP (SQFT/NO)</th>
                            <th style="width:15%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">DISC (SQFT/NO)</th>
                            <th style="width:10%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">TOTAL</th>
                            <th style="width:7%; border:1px solid #cfcfcf; text-align:center; font-weight:bold;">IMAGE</th>
                        </tr>
                    </thead>
                    
                    <tbody style="font-weight:normal;">
                        
                        <apex:repeat value="{!areaGroups}" var="grp">
                            
                            <apex:variable var="counter" value="{!1}"/>
                            
                            <apex:repeat value="{!grp.items}" var="item">
                                
                                <tr style="font-size:16px; font-weight:normal;">
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">{!counter}</td>
                                    <td style="border:1px solid #cfcfcf; font-weight:normal; padding:4px 10px;">{!item.description}</td>
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">{!item.areaDisplay}</td>
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">{!item.sqft}</td>
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">{!item.quantity}</td>
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;"><apex:outputText value="{0, number, ##,##0.00}">
                                        <apex:param value="{!item.unitPrice}" />
                                    </apex:outputText></td>
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">

                                        <!-- If Percentage -->
                                        <apex:outputText rendered="{!item.discountType == 'Percentage'}"
                                                         value="{0, number, ##,##0.00}">
                                            <apex:param value="{!item.discountAmountInRupees}" />
                                        </apex:outputText>
                                    
                                        <!-- If Amount -->
                                        <apex:outputText rendered="{!item.discountType == 'Amount'}"
                                                         value="{0, number, ##,##0.00}">
                                            <apex:param value="{!item.discountValue}" />
                                        </apex:outputText>
                                    
                                    </td>
                                    <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">{!item.total}</td>
                                    <td style="border:1px solid #cfcfcf;"></td>
                                </tr>
                                
                                <apex:variable var="counter" value="{!counter+1}"/>
                                
                            </apex:repeat>
                            
                            <tr>
                                <td colspan="7" style="border:1px solid #cfcfcf; text-align:right; font-weight:normal;">
                                    SET TOTAL
                                </td>
                                <td style="border:1px solid #cfcfcf; text-align:center; font-weight:normal;">
                                    {!grp.areaTotal}
                                </td>
                                <td style="border:1px solid #cfcfcf;"></td>
                            </tr>
                            
                        </apex:repeat>
                        
                    </tbody>
                </table>
                
                
                
                
                
                
            </div>
            
            <div class="totals-section" style="margin-top:0; width: auto; margin-left:1cm;  margin-right:1cm;">
                <table width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse; margin-top: 0;">
                <!--    <tr>
                        <td style="border: 1px solid #cfcfcf; padding: 4px 10px; width: 59%;"></td>
                        <td style="border: 1px solid #cfcfcf; padding: 4px 10px; font-size: 15px; font-weight:normal; width: 16%;">MRP Total</td>
                        <td style="border: 1px solid #cfcfcf; padding: 4px 10px; text-align: right; font-size: 15px; font-weight:normal; width: 20%;">
                            <apex:outputText value="{0, number, ###,##0.00}">
                                <apex:param value="{!mrpTotal}"/>
                            </apex:outputText>
                        </td>
                    </tr>-->
                    
