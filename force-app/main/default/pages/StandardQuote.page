            <div style="width:100%; margin:0; padding:0;">
                <apex:image url="{!URLFOR($Resource.componyLogo1)}"
                            style="display:block; width:100%; height:auto; margin:0; padding:0;"
                            alt="Company Logo"/>
            </div>
            <div style="width:100%; border-top:1px solid #cfcfcf; margin:10px 0;"></div>
            <table style="width:100%; border-collapse:collapse; margin-top:10px; font-size:15px; margin-left:1cm;  margin-right:1cm;">
                
                <tr>
                    
                    <!-- LEFT SIDE -->
                    <td style="width:50%; vertical-align:top; padding:10px;">
                        
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="font-weight:bold;">Company <br/>Address</td>
                                <td>Le Marble Gallery<br/>
                                    Opposite Civil Station, Calicut
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="height:20px;"></td>
                            </tr>
                            <tr>
                                <td style="font-weight:bold;">Prepared By</td>
                                <td>{!cart.Owner.Name}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Phone</td>
                                <td>{!cart.Owner.Phone}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Email</td>
                                <td>{!cart.Owner.Email}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Bill To Name</td>
                                <td>{!Quote.Account.Name}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Bill To</td>
                                <td><apex:outputText value="{!Quote.Opportunity.Account.BillingStreet}" rendered="{!NOT(ISBLANK(Quote.Opportunity.Account.BillingStreet))}"/><br/>
                                    <apex:outputText value="{!Quote.Opportunity.Account.BillingCity}" rendered="{!NOT(ISBLANK(Quote.Opportunity.Account.BillingCity))}"/>
                                    <apex:outputText value=", {!Quote.Opportunity.Account.BillingState}" rendered="{!NOT(ISBLANK(Quote.Opportunity.Account.BillingState))}"/>
                                    <apex:outputText value=", {!Quote.Opportunity.Account.BillingCountry}" rendered="{!NOT(ISBLANK(Quote.Opportunity.Account.BillingCountry))}"/>
                                </td>
                            </tr>
                        </table>
                        
                    </td>
                    
                    
                    <!-- RIGHT SIDE -->
                    <td style="width:50%; vertical-align:top; padding:8px;">
                        
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="font-weight:bold;">Created Date</td>
                                <td>
                                    {!LPAD(TEXT(DAY(DATEVALUE(cart.CreatedDate))), 2, '0')}-
                                    {!LPAD(TEXT(MONTH(DATEVALUE(cart.CreatedDate))), 2, '0')}-
                                    {!TEXT(YEAR(DATEVALUE(cart.CreatedDate)))}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Expiration Date</td>
                                <td>
                                    
                                    {!LPAD(TEXT(DAY(cart.ExpirationDate)), 2, '0')}-
                                    {!LPAD(TEXT(MONTH(Quote.ExpirationDate)), 2, '0')}-
                                    {!TEXT(YEAR(Quote.ExpirationDate))}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Quote Number</td>
                                <td>{!cart.Name}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Contact Name</td>
                                <td>{!cart.Contact_Person_Name__c}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Phone</td>
                                <td>{!cart.Contact_Person_Number__c}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Email</td>
                                <td>{!cart.Email}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Ship To Name</td>
                                <td>{!cart.QuoteToName}</td>
                            </tr>
                            
                            <tr>
                                <td style="font-weight:bold;">Ship To</td>
                                <td><apex:outputText value="{!Quote.AddressLine1__c}" rendered="{!NOT(ISBLANK(Quote.AddressLine1__c ))}"/><br/>
                                    <apex:outputText value="{!Quote.AddressLine2__c}" rendered="{!NOT(ISBLANK(Quote.AddressLine2__c))}"/>
                                    <!--    <apex:outputText value=", {!Quote.AddressLine3__c}" rendered="{!NOT(ISBLANK(Quote.AddressLine3__c))}"/> -->
                                    <apex:outputPanel rendered="{!NOT(ISBLANK(Quote.AddressLine3__c))}">
                                        <br/>
                                        <apex:outputText value="{!Quote.AddressLine3__c}"/>
                                    </apex:outputPanel>
                                    
                                    <apex:outputText value=", {!Quote.District__c}" rendered="{!NOT(ISBLANK(Quote.District__c))}"/>
                                    <apex:outputText value=", {!Quote.State__c}" rendered="{!NOT(ISBLANK(Quote.State__c))}"/>
                                    <apex:outputText value=", {!Quote.Country__c}" rendered="{!NOT(ISBLANK(Quote.Country__c))}"/>
                                </td>
                            </tr>
                        </table>
                        
                    </td>
                    
                </tr>
                
            </table>
            
            
            
            
            
            <div style="margin-bottom: 15px; font-size: 18px; margin-left:1cm;  margin-right:1cm;" class="dear-content">
                <p style="margin: 0;">Dear Sir/Madam,</p>
                <p style="margin: 10px 0 0 0;">Thank you for choosing Le Marble Gallery. In response to your enquiry, we take pleasure in furnishing our lowest rate for your kind consideration.</p>
            </div>
            
            <div style="overflow-x:auto; width:100%;">
