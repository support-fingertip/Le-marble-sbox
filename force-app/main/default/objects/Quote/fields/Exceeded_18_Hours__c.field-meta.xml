<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Exceeded_18_Hours__c</fullName>
    <externalId>false</externalId>
    <formula>AND(
 ISPICKVAL(Approval_Status__c , &quot;Approved&quot;),
 NOT(Quotation_Sent_to_Customer__c),
 NOT(ISBLANK(Quotation_Approved_DateTime__c)),
 Hours_Since_Approval__c &gt;= 18
)</formula>
    <label>Exceeded 18 Hours</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
