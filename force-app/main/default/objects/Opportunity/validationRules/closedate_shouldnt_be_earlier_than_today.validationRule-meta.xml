<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>closedate_shouldnt_be_earlier_than_today</fullName>
    <active>true</active>
    <errorConditionFormula>CloseDate &lt; 
IF(
    ISNEW(),
    TODAY(),
    DATEVALUE(CreatedDate)
)</errorConditionFormula>
    <errorDisplayField>CloseDate</errorDisplayField>
    <errorMessage>Close Date cannot be earlier than the record creation date</errorMessage>
</ValidationRule>
